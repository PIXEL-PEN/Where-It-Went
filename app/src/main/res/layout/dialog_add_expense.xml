<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="4dp">

        <!-- ============================
             CARD 1 — DAILY LIVING
        ============================ -->
        <LinearLayout
            android:id="@+id/card_daily"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:elevation="6dp"
            android:padding="20dp">

            <TextView
                android:id="@+id/header_daily"
                android:text="DAILY LIVING"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#444444"
                android:paddingBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Spinner
                android:id="@+id/spinner_category"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:paddingStart="4dp"
                android:paddingEnd="8dp" />

            <TextView
                android:id="@+id/text_tag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fixed"
                android:textColor="#888888"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="end"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/input_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Item"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/input_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Amount"
                android:inputType="numberDecimal"
                android:textSize="16sp"
                android:layout_marginTop="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/text_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22 Dec 2025"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

                <ImageView
                    android:id="@+id/icon_calendar"
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="#000000" />
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btn_ok"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/btn_ok_square"
                    android:text="OK"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:padding="0dp"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="15dp" />

        <!-- ============================
             CARD 2 — ACCOUNTS
        ============================ -->
    <LinearLayout
        android:id="@+id/card_other"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/header_other_accounts"
                android:text="ACCOUNTS"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#444444"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/text_add_account"
                android:text="+ Add Account"
                android:textColor="#0066CC"
                android:textSize="14sp"
                android:padding="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btn_account_submit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUBMIT ACCOUNT"
                android:layout_marginTop="12dp" />



        </LinearLayout>

        <TextView
            android:id="@+id/text_no_accounts"
            android:text="No accounts created yet."
            android:textColor="#777777"
            android:textSize="13sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/container_account_entry"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical">

                <Spinner
                    android:id="@+id/spinner_account_project"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1" />

                <Spinner
                    android:id="@+id/spinner_account_category"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp" />

                <ImageButton
                    android:id="@+id/btn_add_account_category"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_add"
                    android:background="@drawable/bg_add_small"
                    android:padding="6dp"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:contentDescription="Add category" />

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">

                <EditText
                    android:id="@+id/input_account_item"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:hint="Item"
                    android:inputType="textCapSentences"
                    android:textSize="14sp" />


                <EditText
                    android:id="@+id/input_account_amount"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Amount"
                    android:inputType="numberDecimal"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">



                <EditText
                    android:id="@+id/input_account_note"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="4dp"
                    android:hint="Note"
                    android:inputType="textCapSentences"
                    android:textSize="14sp" />


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/text_account_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01 Jan 2025"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#666666"
                        android:padding="4dp"/>

                    <ImageView
                        android:id="@+id/icon_calendar"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_calendar"
                        android:tint="#666666"/>

                </LinearLayout>




                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/text_account_submit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUBMIT"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#666666" />
            </LinearLayout>



        </LinearLayout>

    </LinearLayout>

    </LinearLayout>

</ScrollView>
