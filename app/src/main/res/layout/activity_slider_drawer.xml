<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/slider_drawer"
    android:orientation="vertical"
    android:layout_width="230dp"
    android:layout_height="match_parent"
    android:background="#0B4B6E"
    android:padding="0dp">

    <!-- Top blue bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#0D5D8A" />

    <!-- White spacer containing the plane icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#ECEFF1">

        <ImageView
            android:id="@+id/slider_logo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_plane_icon"
            android:adjustViewBounds="true"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Lower dark strip -->
    <View
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="#0D5D8A" />

    <!-- Scrollable links -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#ECEFF1">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="24dp"
            android:paddingBottom="32dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/linkSettings"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:paddingVertical="6dp"
                android:gravity="center"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#024265" />

            <TextView
                android:id="@+id/linkCategoryFilter"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:paddingVertical="6dp"
                android:gravity="center"
                android:text="Category Filter"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#024265" />

            <TextView
                android:id="@+id/linkDistribution"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:paddingVertical="6dp"
                android:gravity="center"
                android:text="Distribution"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#024265" />

            <TextView
                android:id="@+id/linkTutorial"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:paddingVertical="6dp"
                android:gravity="center"
                android:text="Tutorial"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#024265" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
