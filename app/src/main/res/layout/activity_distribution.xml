<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_distribution"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1">

    <RelativeLayout
        android:id="@+id/top_bar_container"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="@color/colorPrimary"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="3dp">

        <LinearLayout
            android:id="@+id/title_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@null"
                android:src="@drawable/ic_arrow_back_white"
                android:contentDescription="@string/back"
                android:translationY="1dp"
                android:tint="@android:color/white" />

            <TextView
                android:id="@+id/topBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btn_back"
                android:layout_marginStart="8dp"
                android:layout_centerVertical="true"
                android:text="Distribution"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:translationY="1dp"
                android:includeFontPadding="false" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/content"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/top_bar_container"
        android:gravity="center"
        android:padding="16dp"
        android:layout_marginTop="-160dp">

        <com.pixelpen.whereitwent.SimplePieView
            android:id="@+id/pie"
            android:layout_width="260dp"
            android:layout_height="260dp" />

        <LinearLayout
            android:id="@+id/legend_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="#0D5D8A" />

                <TextView
                    android:id="@+id/legend_fixed_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Fixed"
                    android:textSize="14sp"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/legend_fixed_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#222222"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/legend_fixed_delta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="#BFCBD3" />

                <TextView
                    android:id="@+id/legend_basic_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Necessities"
                    android:textSize="14sp"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/legend_basic_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#222222"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/legend_basic_delta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="#FFDDC1" />

                <TextView
                    android:id="@+id/legend_disc_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Discretionary"
                    android:textSize="14sp"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/legend_disc_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#222222"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/legend_disc_delta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
