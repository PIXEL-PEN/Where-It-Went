<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top bar -->
        <RelativeLayout
            android:id="@+id/top_bar_container"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:background="@color/colorPrimary"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/top_bar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="13dp"
                android:text="Expenditures"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <ImageButton
                android:id="@+id/btn_filter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_alignBottom="@id/top_bar_title"
                android:layout_marginBottom="-6dp"
                android:src="@drawable/ic_hamburger"
                android:tint="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"/>
        </RelativeLayout>

        <!-- Month banner -->
        <LinearLayout
            android:id="@+id/month_banner"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_below="@id/top_bar_container"
            android:paddingStart="12dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:background="@android:color/white">

            <!-- Back triangle -->
            <ImageButton
                android:id="@+id/btn_prev_month"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_triangle_left"
                android:background="@android:color/transparent"
                android:tint="#333333"
                android:padding="10dp" />

            <!-- pull title closer to left arrow -->
            <TextView
                android:id="@+id/text_month_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-10dp"
                android:layout_marginEnd="-10dp"
                android:text="November 2025"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Forward triangle -->
            <ImageButton
                android:id="@+id/btn_next_month"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_triangle_right"
                android:background="@android:color/transparent"
                android:tint="#333333"
                android:padding="10dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/text_month_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 ₱"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#CC0000" />
        </LinearLayout>

        <!-- Divider under banner -->
        <View
            android:id="@+id/banner_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#000000"
            android:layout_below="@id/month_banner"/>

        <!-- Month list -->
        <LinearLayout
            android:id="@+id/month_list"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/banner_divider"
            android:paddingTop="4dp">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">

                <!-- Stacked date -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nov"
                        android:textSize="12sp"
                        android:layout_marginTop="3dp"
                        android:textColor="#666666"/>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#000000"/>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- Amount + ₱ -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="end|center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/amount_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="230.00"
                        android:textColor="#333333"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ₱"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#333333"/>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dividerGray"/>

            <!-- Row 2 (sample) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical">

                <!-- Stacked date -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nov"
                        android:textSize="12sp"
                        android:layout_marginTop="3dp"
                        android:textColor="#666666"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="02"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#000000"/>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- Amount -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="end|center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/amount_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:textColor="#333333"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ₱"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#333333"/>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dividerGray"/>
        </LinearLayout>

        <!-- FAB -->
        <ImageButton
            android:id="@+id/fab_add"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="90dp"
            android:background="@drawable/fab_button_flat"
            android:src="@drawable/ic_add_plus"
            android:tint="@android:color/white"/>
    </RelativeLayout>

    <!-- Drawer -->
    <include
        android:id="@+id/include_drawer"
        layout="@layout/activity_slider_drawer"
        android:layout_width="235dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"/>
</androidx.drawerlayout.widget.DrawerLayout>
