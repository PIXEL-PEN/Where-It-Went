<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1">

    <!-- Top bar -->
    <TextView
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:gravity="bottom|start"
        android:paddingStart="16dp"
        android:paddingBottom="16dp"
        android:text="Where It Went"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:background="@color/colorPrimary" />


    <!-- Spacer pushes buttons downward -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="11"/>

    <!-- Buttons container -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp"
        android:layout_marginBottom="48dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnViewAll"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_button_accent"

            android:backgroundTint="@null"
            android:text="View All Expenses"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="19sp"
            android:layout_marginBottom="16dp"
            android:elevation="6dp"
            android:translationZ="3dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDateWise"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_button_accent"

            android:backgroundTint="@null"
            android:text="Expenses by Date"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="19sp"
            android:layout_marginBottom="16dp"
            android:elevation="6dp"
            android:translationZ="3dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMonthWise"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_button_accent"

            android:backgroundTint="@null"
            android:text="Expenses by Month"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="19sp"
            android:layout_marginBottom="16dp"
            android:elevation="6dp"
            android:translationZ="3dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCategoryWise"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_button_accent"

            android:backgroundTint="@null"
            android:text="Expenses by Category"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="19sp"
            android:elevation="6dp"
            android:translationZ="3dp"/>
    </LinearLayout>

    <!-- Bottom spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="7"/>

    <!-- Floating Add Expense button -->
    <ImageButton
        android:id="@+id/fab_add"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="90dp"
        android:background="@drawable/fab_button_flat"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_add_plus"
        android:tint="@android:color/white"
        android:contentDescription="Add Expense"
        android:elevation="8dp"
        android:padding="0dp"
        android:stateListAnimator="@null"/>


</LinearLayout>
