<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content area -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#ECEFF1">

        <!-- Top bar -->
        <RelativeLayout
            android:id="@+id/top_bar_container"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:background="@color/colorPrimary"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/top_bar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="16dp"
                android:text="Where It Went"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- ✅ Hamburger button (controls right slider) -->
            <ImageButton
                android:id="@+id/btn_filter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_alignBottom="@id/top_bar_title"
                android:layout_marginBottom="-6dp"
                android:src="@drawable/ic_filter_list"
                android:tint="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:padding="10dp" />
        </RelativeLayout>

        <!-- Spacer pushes buttons downward -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="11" />

        <!-- Buttons container -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingHorizontal="32dp"
            android:layout_marginBottom="48dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnViewAll"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_button_accent"
                android:backgroundTint="@null"
                android:text="View All Expenses"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="19sp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp"
                android:translationZ="3dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDateWise"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_button_accent"
                android:backgroundTint="@null"
                android:text="Expenses by Date"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="19sp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp"
                android:translationZ="3dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMonthWise"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_button_accent"
                android:backgroundTint="@null"
                android:text="Expenses by Month"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="19sp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp"
                android:translationZ="3dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCategoryWise"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_button_accent"
                android:backgroundTint="@null"
                android:text="Expenses by Category"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="19sp"
                android:elevation="6dp"
                android:translationZ="3dp" />
        </LinearLayout>

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="7" />

        <!-- Floating Add Expense button -->
        <ImageButton
            android:id="@+id/fab_add"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="25dp"
            android:layout_marginBottom="90dp"
            android:background="@drawable/fab_button_flat"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add_plus"
            android:tint="@android:color/white"
            android:contentDescription="Add Expense"
            android:elevation="8dp"
            android:padding="0dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- ✅ Right-side slider -->
    <include
        android:id="@+id/include_drawer"
        layout="@layout/activity_slider_drawer"
        android:layout_width="235dp"
        android:layout_height="match_parent"
        android:layout_gravity="end" />

</androidx.drawerlayout.widget.DrawerLayout>
